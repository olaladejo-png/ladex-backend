{
    "kind": "collectionType",
    "collectionName": "guideline_documents",
    "info": {
        "singularName": "guideline-document",
        "pluralName": "guideline-documents",
        "displayName": "Guideline & Document",
        "description": "Regulatory guidelines, PDFs and technical documents"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true,
            "maxLength": 255
        },
        "description": {
            "type": "text",
            "maxLength": 600
        },
        "file": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "files",
                "images",
                "videos"
            ]
        },
        "category": {
            "type": "enumeration",
            "enum": [
                "General",
                "Logistics",
                "Nutrition",
                "Reports",
                "Other"
            ],
            "default": "General",
            "required": true
        },
        "published_date": {
            "type": "date"
        },
        "file_size": {
            "type": "string"
        },
        "is_featured": {
            "type": "boolean",
            "default": false
        }
    }
}