{
    "kind": "singleType",
    "collectionName": "about_pages",
    "info": {
        "singularName": "about-page",
        "pluralName": "about-pages",
        "displayName": "About Page",
        "description": "Content for the About page: mission, vision, values, objectives"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "mission": {
            "type": "text",
            "required": true
        },
        "vision": {
            "type": "text"
        },
        "hero_tagline": {
            "type": "string",
            "maxLength": 255
        },
        "hero_image": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "body": {
            "type": "richtext"
        },
        "objectives": {
            "type": "text"
        },
        "background": {
            "type": "text"
        },
        "values": {
            "type": "component",
            "repeatable": true,
            "component": "blocks.text-item"
        },
        "objectives_list": {
            "type": "component",
            "repeatable": true,
            "component": "blocks.text-item"
        },
        "seo": {
            "type": "component",
            "repeatable": false,
            "component": "shared.seo"
        }
    }
}
